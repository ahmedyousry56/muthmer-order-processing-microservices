generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["partialIndexes"]
}

datasource db {
  provider = "postgresql"
}

model customers {
  id         String    @id @default(dbgenerated("uuidv7()")) @db.Uuid
  first_name String    @db.VarChar(50)
  last_name  String    @db.VarChar(50)
  email      String    @unique(map: "idx_customers_email_unique") @db.VarChar(255)
  password   String
  created_at DateTime  @default(now()) @db.Timestamptz(6)
  updated_at DateTime? @db.Timestamptz(6)
  deleted_at DateTime? @db.Timestamptz(6)
  orders     orders[]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model items {
  id          String        @id @default(dbgenerated("uuidv7()")) @db.Uuid
  name        String
  description String?
  price       Decimal       @db.Decimal(10, 2)
  sku         String        @unique(map: "idx_items_sku_unique")
  stock       Int           @default(0)
  created_at  DateTime      @default(now()) @db.Timestamptz(6)
  updated_at  DateTime?     @db.Timestamptz(6)
  deleted_at  DateTime?     @db.Timestamptz(6)
  order_items order_items[]

  @@index([created_at(sort: Desc)], map: "idx_items_created_at")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model order_items {
  id         String    @id @default(dbgenerated("uuidv7()")) @db.Uuid
  order_id   String    @db.Uuid
  item_id    String    @db.Uuid
  quantity   Int
  unit_price Decimal   @db.Decimal(10, 2)
  created_at DateTime  @default(now()) @db.Timestamptz(6)
  updated_at DateTime? @db.Timestamptz(6)
  deleted_at DateTime? @db.Timestamptz(6)
  items      items     @relation(fields: [item_id], references: [id], onUpdate: NoAction)
  orders     orders    @relation(fields: [order_id], references: [id], onUpdate: NoAction)

  @@unique([order_id, item_id], map: "idx_order_items_order_id_item_id_unique")
}

model orders {
  id               String             @id @default(dbgenerated("uuidv7()")) @db.Uuid
  customer_id      String             @db.Uuid
  status           order_status       @default(PENDING)
  failure_reason   String?
  created_at       DateTime           @default(now()) @db.Timestamptz(6)
  updated_at       DateTime?          @db.Timestamptz(6)
  deleted_at       DateTime?          @db.Timestamptz(6)
  order_items      order_items[]
  customers        customers          @relation(fields: [customer_id], references: [id], onUpdate: NoAction)
  processed_events processed_events[]

  @@index([created_at(sort: Desc)], map: "idx_orders_created_at")
  @@index([status], map: "idx_orders_status", where: raw("(deleted_at IS NULL)"))
}

model processed_events {
  id           String   @id @db.Uuid
  order_id     String?  @db.Uuid
  topic        String
  processed_at DateTime @default(now()) @db.Timestamptz(6)
  orders       orders?  @relation(fields: [order_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([topic], map: "idx_processed_events_topic")
}

enum order_status {
  PENDING
  CONFIRMED
  FAILED
}
