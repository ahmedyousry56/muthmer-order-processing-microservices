{
  "name": "@muthmer-order-processing/source",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "prisma:generate": "prisma db pull && prisma generate --schema=libs/shared/prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema=libs/shared/prisma/schema.prisma",
    "prisma:deploy": "prisma migrate deploy --schema=libs/shared/prisma/schema.prisma",
    "prisma:seed": "prisma db seed",
    "prisma:studio": "prisma studio --schema=libs/shared/prisma/schema.prisma",
    "start:orders": "nx serve orders-service",
    "build:orders": "nx build orders-service",
    "start:inventory": "nx serve inventory-service",
    "build:inventory": "nx build inventory-service",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "private": true,
  "devDependencies": {
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@nx/jest": "23.0.0",
    "@nx/js": "23.0.0",
    "@nx/nest": "^23.0.0",
    "@nx/node": "23.0.0",
    "@nx/web": "23.0.0",
    "@nx/webpack": "23.0.0",
    "@swc/helpers": "~0.5.18",
    "@swc/jest": "~0.2.38",
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/jest": "~30.0.0",
    "@types/node": "^22.0.0",
    "@types/passport-jwt": "^4.0.1",
    "husky": "^9.1.7",
    "jest": "~30.3.0",
    "jest-environment-node": "~30.3.0",
    "jest-util": "~30.3.0",
    "lint-staged": "^17.0.8",
    "nx": "23.0.0",
    "prettier": "~3.6.2",
    "prisma": "^7.8.0",
    "ts-jest": "^29.4.0",
    "ts-node": "10.9.1",
    "tslib": "^2.3.0",
    "typescript": "~5.9.2",
    "webpack": "^5.101.3",
    "webpack-cli": "^7.0.0",
    "webpack-dev-server": "^5.2.1"
  },
  "workspaces": [
    "packages/*",
    "apps/*",
    "libs/*",
    "database"
  ],
  "dependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.0.0",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/microservices": "^11.1.27",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/swagger": "^11.4.4",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "axios": "^1.6.0",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "cookie-parser": "^1.4.7",
    "kafkajs": "^2.2.4",
    "nestjs-i18n": "^10.8.4",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.22.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0",
    "yup": "^1.7.1"
  },
  "lint-staged": {
    "**/*.{js,ts,json,md,yaml,yml}": [
      "prettier --write"
    ]
  },
  "prisma": {
    "seed": "ts-node libs/shared/prisma/seed/index.ts"
  }
